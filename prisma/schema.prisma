// daon-backend\prisma\schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// 관리자 계정 모델 (계정 정보 수정 기능 대응 규격)
model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String?
  phone     String?  // 🔑 추가: 전화번호 정보 컬럼
  role      String   @default("일반 관리자") // 🔑 변경: 등급 정보 기본값을 프론트엔드 기본 핏에 일치 ("일반 관리자", "최고 관리자")
  
  // 🔑 [신규 추가] 5분 비밀번호 리셋용 인스턴스 키 관련 스펙
  resetKey        String?   @db.VarChar(8)
  resetKeyExpires DateTime?

  createdAt DateTime @default(now())
}

// 게시판 모델 (공지사항 등)
model Post {
  id          Int      @id @default(autoincrement())
  title       String
  content     String   @db.LongText
  category    String

  clientName  String?
  workAddress String?
  workLat     Float?
  workLng     Float?

  // ✨ [신규 추가] 작업년도 / 작업월
  workYear    Int?
  workMonth   Int?

  createdAt   DateTime @default(now())
  files       File[]
  keywords    PostKeyword[]
}

model File {
  id        Int    @id @default(autoincrement())
  url       String
  name      String
  type      String // 'image', 'document', 'archive'
  postId    Int
  post      Post   @relation(fields: [postId], references: [id])
}

// ✨ [신규] 작업 키워드 마스터 테이블 (검색/카테고리 확장용)
model Keyword {
  id    Int           @id @default(autoincrement())
  name  String        @unique
  posts PostKeyword[]
}

model PostKeyword {
  postId    Int
  keywordId Int
  post      Post    @relation(fields: [postId], references: [id], onDelete: Cascade)
  keyword   Keyword @relation(fields: [keywordId], references: [id], onDelete: Cascade)

  @@id([postId, keywordId])
}

// 고객 문의 수집 모델
model Inquiry {
  id        Int      @id @default(autoincrement())
  name      String
  email     String?
  contact   String
  message   String   @db.Text
  status    String   @default("PENDING") // PENDING, DONE
  createdAt DateTime @default(now())
}

// 회사정보 모델
model Company {
  id            Int      @id @default(autoincrement())
  name          String?
  ceo           String?
  bizNumber     String?
  address       String?  // 도로명 주소 (예: 서울 강남구 도곡로 222)
  addressDetail String? // 상세주소 (예: 3층 다온씨엔이)
  phone         String?
  email         String?
  fax           String?
  lat           Float?
  lng           Float?
  updatedAt     DateTime @updatedAt
}

// 견적문의 게시판
model Quote {
  id               Int       @id @default(autoincrement())
  company          String?
  name             String
  phone            String
  email            String
  title            String
  content          String    @db.Text
  isSecret         Boolean   @default(true)
  password         String?
  status           String    @default("접수대기")
  reply            String?   @db.Text
  replyAt          DateTime?
  privacyAgreement Boolean   @default(false) // 개인정보 동의 여부 필드
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

// 메인 슬라이드
model MainSlide {
  id          Int      @id @default(autoincrement())
  title       String   // 배너 대제목
  description String?  // 배너 간단 설명
  videoUrl    String   // 영상 파일 경로 또는 외부 스트리밍 URL
  isExposed   Boolean  @default(false) // 메인 노출 여부 (체크 시 노출)
  duration    Int      @default(5)     // 슬라이드 유지 시간 (초 단위, 기본값 5초)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}


// 개인정보처리방침 및 이용약관 통합 관리 모델
model Policy {
  id            Int      @id @default(autoincrement())
  title         String   
  content       String   @db.LongText 
  type          String   
  isExposed     Boolean  @default(false) 
  effectiveDate String?  // 🔑 이 컬럼이 추가되어 있는지 꼭 확인해 주세요! (DateTime? 도 무방합니다.)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}