// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// 1. 관리자 계정 모델
model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String?
  role      String   @default("ADMIN")
  createdAt DateTime @default(now())
}

// 2. 게시판 모델 (공지사항 등)
model Post {
  id        Int      @id @default(autoincrement())
  title     String
  content   String   @db.LongText  // 마크다운은 내용이 길 수 있으므로 LongText
  category  String   // '현장사진', '공사실적', '보유장비'
  createdAt DateTime @default(now())
  files     File[]
}

model File {
  id        Int    @id @default(autoincrement())
  url       String
  name      String
  type      String // 'image', 'document', 'archive'
  postId    Int
  post      Post   @relation(fields: [postId], references: [id])
}

// 3. 고객 문의 수집 모델
model Inquiry {
  id        Int      @id @default(autoincrement())
  name      String
  email     String?
  contact   String
  message   String   @db.Text
  status    String   @default("PENDING") // PENDING, DONE
  createdAt DateTime @default(now())
}

// 4. 회사정보 모델
model Company {
  id           Int      @id @default(autoincrement())
  name         String?
  ceo          String?
  bizNumber    String?
  address      String?  // 도로명 주소 (예: 서울 강남구 도곡로 222)
  addressDetail String? // ✅ 추가: 상세주소 (예: 3층 다온씨엔이)
  phone        String?
  email        String?
  fax          String?
  lat          Float?
  lng          Float?
  updatedAt    DateTime @updatedAt
}

// 견적문의 게시판
model Quote {
  id               Int      @id @default(autoincrement())
  company          String?
  name             String
  phone            String
  email            String
  title            String
  content          String   @db.Text
  isSecret         Boolean  @default(true)
  password         String?
  status           String   @default("접수대기")
  reply            String?  @db.Text
  replyAt          DateTime?
  privacyAgreement Boolean  @default(false) // 🔥 [추가] 개인정보 동의 여부 필드
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}